{% extends 'base.html.twig' %}

{% block title %}Create account{% endblock %}

{% block body %}
<h1>Create account</h1>

<form action="{{ path('app_register') }}" method="POST" class="auth-form">
    <label class="auth-form__label" for="inputEmail">Email</label>
    <input type="email" value="{{ last_email }}" name="email" id="inputEmail"
           class="auth-form__input" autocomplete="email" required autofocus>

    <label class="auth-form__label" for="inputPassword">Password</label>
    <input type="password" name="password" id="inputPassword"
           class="auth-form__input" autocomplete="new-password" minlength="6" required>

    <input type="hidden" name="_csrf_token" value="{{ csrf_token('register') }}">

    <button type="submit" class="auth-form__button">Create account</button>
</form>

<p class="auth-switch">Already have an account? <a href="{{ path('app_login') }}">Sign in</a>.</p>
{% endblock %}
