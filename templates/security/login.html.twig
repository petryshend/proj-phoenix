{% extends 'base.html.twig' %}

{% block title %}Sign in{% endblock %}

{% block body %}
<h1>Sign in</h1>

{% if error %}
    <article class="flash-message pico-color-red-2">{{ error.messageKey|trans(error.messageData, 'security') }}</article>
{% endif %}

<form action="{{ path('app_login') }}" method="POST" class="auth-form">
    <label class="auth-form__label" for="inputEmail">Email</label>
    <input type="email" value="{{ last_username }}" name="_username" id="inputEmail"
           class="auth-form__input" autocomplete="email" required autofocus>

    <label class="auth-form__label" for="inputPassword">Password</label>
    <input type="password" name="_password" id="inputPassword"
           class="auth-form__input" autocomplete="current-password" required>

    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

    <button type="submit" class="auth-form__button">Sign in</button>
</form>

<p class="auth-switch">No account yet? <a href="{{ path('app_register') }}">Create one</a>.</p>
{% endblock %}
