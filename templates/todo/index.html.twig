{% extends 'base.html.twig' %}

{% block title %}Todo List{% endblock %}

{% block body %}
<h1>Todo List</h1>

<form action="{{ path('todo_new') }}" method="POST" style="margin-bottom: 1rem;">
    <input type="text" name="title" placeholder="New todo..." required>
    <button type="submit">Add</button>
</form>

{% if todos is empty %}
    <p>No todos yet. Add one above!</p>
{% else %}
    <ul style="list-style: none; padding: 0;">
        {% for todo in todos %}
            <li style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.4rem;">
                <span style="{{ todo.done ? 'text-decoration: line-through; color: #888;' : '' }}">
                    {{ todo.title }}
                </span>
                <form action="{{ path('todo_toggle', {id: todo.id}) }}" method="POST">
                    <button type="submit">{{ todo.done ? '↩' : '✓' }}</button>
                </form>
                <form action="{{ path('todo_delete', {id: todo.id}) }}" method="POST">
                    <button type="submit">✕</button>
                </form>
            </li>
        {% endfor %}
    </ul>
{% endif %}
{% endblock %}
