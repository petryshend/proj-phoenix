{% extends 'base.html.twig' %}

{% block title %}Todo List{% endblock %}

{% block body %}
<h1>Todo List</h1>

<form action="{{ path('todo_new') }}" method="POST" class="add-form">
    <input type="text" name="title" placeholder="New todo..." required class="add-form__input">
    <button type="submit" class="add-form__button">Add</button>
</form>

{% if todos is empty %}
    <p><em>No todos yet. Add one above!</em></p>
{% else %}
    <ul class="todo-list">
        {% for todo in todos %}
            <li class="todo-item">
                <span class="todo-content">
                    <span class="{{ todo.done ? 'todo-title--done' : '' }}">
                        {{ todo.title }}
                    </span>
                    <br>
                    <small class="todo-meta">
                        Created: {{ todo.createdAt|date('d M Y, H:i') }}
                        {% if todo.doneAt %}· Done: {{ todo.doneAt|date('d M Y, H:i') }}{% endif %}
                    </small>
                </span>
                <form action="{{ path('todo_toggle', {id: todo.id}) }}" method="POST" class="todo-action-form">
                    <button type="submit" class="outline todo-action-btn">
                        {{ todo.done ? '↩' : '✓' }}
                    </button>
                </form>
                <form action="{{ path('todo_delete', {id: todo.id}) }}" method="POST" class="todo-action-form">
                    <button type="submit" class="outline secondary todo-action-btn">✕</button>
                </form>
            </li>
        {% endfor %}
    </ul>

    {% if totalPages > 1 %}
        <nav class="pagination">
            {% if currentPage > 1 %}
                <a href="{{ path('todo_index', {page: currentPage - 1}) }}" class="pagination__link">‹ Prev</a>
            {% endif %}
            {% for p in 1..totalPages %}
                <a href="{{ path('todo_index', {page: p}) }}"
                   class="pagination__link {{ p == currentPage ? 'pagination__link--active' : '' }}"
                   {{ p == currentPage ? 'aria-current="page"' : '' }}>{{ p }}</a>
            {% endfor %}
            {% if currentPage < totalPages %}
                <a href="{{ path('todo_index', {page: currentPage + 1}) }}" class="pagination__link">Next ›</a>
            {% endif %}
        </nav>
    {% endif %}
{% endif %}
{% endblock %}
