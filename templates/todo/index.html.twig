{% extends 'base.html.twig' %}

{% block title %}Todo List{% endblock %}

{% block body %}
<h1>Todo List</h1>

<form action="{{ path('todo_new') }}" method="POST" style="display: flex; gap: 0.5rem;">
    <input type="text" name="title" placeholder="New todo..." required style="flex: 1; margin-bottom: 0;">
    <button type="submit">Add</button>
</form>

{% if todos is empty %}
    <p><em>No todos yet. Add one above!</em></p>
{% else %}
    <ul style="list-style: none; padding: 0; margin-top: 1rem;">
        {% for todo in todos %}
            <li style="display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem 0; border-bottom: 1px solid var(--pico-muted-border-color);">
                <span style="flex: 1; {{ todo.done ? 'text-decoration: line-through; color: var(--pico-muted-color);' : '' }}">
                    {{ todo.title }}
                </span>
                <form action="{{ path('todo_toggle', {id: todo.id}) }}" method="POST" style="margin: 0;">
                    <button type="submit" class="outline" style="padding: 0.25rem 0.6rem;">
                        {{ todo.done ? '↩' : '✓' }}
                    </button>
                </form>
                <form action="{{ path('todo_delete', {id: todo.id}) }}" method="POST" style="margin: 0;">
                    <button type="submit" class="outline secondary" style="padding: 0.25rem 0.6rem;">✕</button>
                </form>
            </li>
        {% endfor %}
    </ul>
{% endif %}
{% endblock %}
