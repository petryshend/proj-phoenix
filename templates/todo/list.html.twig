{% extends 'base.html.twig' %}

{% block title %}{{ heading }} Todos{% endblock %}

{% block body %}
<h1>Todo List</h1>

<nav class="todo-nav">
    <a href="{{ path('todo_index') }}"
       class="todo-nav__link {{ route == 'todo_index' ? 'todo-nav__link--active' : '' }}"
       {{ route == 'todo_index' ? 'aria-current="page"' : '' }}>Active ({{ activeCount }})</a>
    <a href="{{ path('todo_done') }}"
       class="todo-nav__link {{ route == 'todo_done' ? 'todo-nav__link--active' : '' }}"
       {{ route == 'todo_done' ? 'aria-current="page"' : '' }}>Done ({{ doneCount }})</a>
</nav>

<form action="{{ path('todo_new') }}" method="POST" class="add-form">
    <input type="text" name="title" placeholder="New todo..." required class="add-form__input">
    <input type="hidden" name="_token" value="{{ csrf_token('todo_new') }}">
    <button type="submit" class="add-form__button">Add</button>
</form>

{% if todos is empty %}
    <p><em>{{ route == 'todo_done' ? 'Nothing completed yet.' : 'No active todos. Add one above!' }}</em></p>
{% else %}
    <ul class="todo-list">
        {% for todo in todos %}
            <li class="todo-item">
                <span class="todo-content">
                    <span class="{{ todo.done ? 'todo-title--done' : '' }}">
                        {{ todo.title }}
                    </span>
                    <br>
                    <small class="todo-meta">
                        Created: {{ todo.createdAt|date('d M Y, H:i') }}
                        {% if todo.doneAt %}· Done: {{ todo.doneAt|date('d M Y, H:i') }}{% endif %}
                    </small>
                </span>
                <form action="{{ path('todo_toggle', {id: todo.id}) }}" method="POST" class="todo-action-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('todo_toggle') }}">
                    <button type="submit" class="outline todo-action-btn">
                        {{ todo.done ? '↩' : '✓' }}
                    </button>
                </form>
                <form action="{{ path('todo_delete', {id: todo.id}) }}" method="POST" class="todo-action-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('todo_delete') }}">
                    <button type="submit" class="outline secondary todo-action-btn">✕</button>
                </form>
            </li>
        {% endfor %}
    </ul>

    {% if totalPages > 1 %}
        <nav class="pagination">
            {% if currentPage > 1 %}
                <a href="{{ path(route, {page: currentPage - 1}) }}" class="pagination__link">‹ Prev</a>
            {% endif %}
            {% for p in 1..totalPages %}
                <a href="{{ path(route, {page: p}) }}"
                   class="pagination__link {{ p == currentPage ? 'pagination__link--active' : '' }}"
                   {{ p == currentPage ? 'aria-current="page"' : '' }}>{{ p }}</a>
            {% endfor %}
            {% if currentPage < totalPages %}
                <a href="{{ path(route, {page: currentPage + 1}) }}" class="pagination__link">Next ›</a>
            {% endif %}
        </nav>
    {% endif %}
{% endif %}
{% endblock %}
